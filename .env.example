# Copia questo file in `.env` e compila i valori.

# --- SVILUPPO LOCALE (Postgres via Docker: docker compose up -d) ---
DATABASE_URL="postgresql://dotto:dotto@localhost:5432/dotto?schema=public"
DIRECT_URL="postgresql://dotto:dotto@localhost:5432/dotto?schema=public"

# --- PRODUZIONE (Vercel Postgres / Neon / Supabase) ---
# DATABASE_URL = connessione "in pool"  (es. ...-pooler...  o ?pgbouncer=true)
# DIRECT_URL   = connessione diretta    (per le migrazioni)
# DATABASE_URL="postgresql://user:password@host-pooler:5432/dotto?sslmode=require"
# DIRECT_URL="postgresql://user:password@host:5432/dotto?sslmode=require"

# Credenziali dell'admin di default creato dal seed
ADMIN_EMAIL="admin@tuodominio.it"
ADMIN_PASSWORD="scegli-una-password"

# Segreto di sessione: genera con `openssl rand -hex 32`
SESSION_SECRET="stringa-lunga-e-casuale"

# URL pubblico del sito (per i QR e gli embed)
NEXT_PUBLIC_BASE_URL="https://dotto.example.com"

# --- Email di conferma (Resend) — opzionale ---
# Se vuote, le email non vengono inviate (la prenotazione funziona comunque).
# Crea una API key su https://resend.com e verifica il dominio del mittente.
RESEND_API_KEY=""
EMAIL_FROM="Dottò <prenotazioni@tuodominio.it>"
